# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="SAP Migration Assessment Agent"
DEBUG=false
LOG_LEVEL=INFO

# ── API Security ──────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sap_agent:sap_agent@postgres:5432/sap_migration
DATABASE_URL_SYNC=postgresql://sap_agent:sap_agent@postgres:5432/sap_migration

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=sap-migration-agent

# ── SAP Connection ────────────────────────────────────────────────────────────
SAP_HOST=your-sap-host
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=RFC_USER
SAP_PASSWORD=your-sap-password
SAP_LANG=EN
SAP_USE_MOCK=true

# ── SAP OData ────────────────────────────────────────────────────────────────
SAP_ODATA_BASE_URL=http://your-sap-host:8080/sap/opu/odata/sap
SAP_ODATA_USER=odata_user
SAP_ODATA_PASSWORD=your-odata-password
